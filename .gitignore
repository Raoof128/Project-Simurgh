node_modules

# secrets — keep .env.example tracked, ignore everything else
.env
.env.*
!.env.example

# OS / editor
.DS_Store
.idea/
.vscode/
*.swp
*.log
npm-debug.log*

# compiled native helpers (Swift outputs)
tools/simurgh-helper/simurgh-helper
tools/verity-helper/verity-helper
tools/invisible-window-poc/invisible-window-poc
tools/**/*.dSYM
tools/**/*.o
tools/**/bin/
tools/**/obj/
# Rust source-level bin/ directories are source, not build artifacts
!tools/**/src/bin/

# audit log / report exports — local only
verity-audit-*.json
simurgh-audit-*.json
simurgh-report-*.json

# runtime data — never commit generated session/audit/report bodies
data/sessions/
data/audit/
data/reports/
data/exams/
logs/

# scripts/check.sh runtime logs
.simurgh_check_logs/
.tools/

# Swift build artifacts inside the macOS node package
tools/simurgh-node-macos/.build/
tools/simurgh-node-macos/.swiftpm/
tools/simurgh-daemon-windows/**/bin/
tools/simurgh-daemon-windows/**/obj/

# tmp
.tmp/
*.tmp

# LaTeX build artifacts
*.aux
*.blg
*.fdb_latexmk
*.fls
*.out
*.synctex.gz
*.toc
*.lof
*.lot
*.bbl
