ANTHROPIC_API_KEY=sk-ant-...
PORT=3030

# Optional — model selection (default: claude-sonnet-4-5)
# Set to claude-haiku-4-5-20251001 for the cost-sensitive deployment tier.
VERITY_MODEL=claude-sonnet-4-5

# Optional — force the local heuristic fallback (no Anthropic calls).
# Useful for offline demos. Default: 0.
VERITY_DEMO_MODE=0

# Native helper auth — must match the --secret flag passed to verity-helper.
VERITY_HELPER_SECRET=verity-dev-helper

# HMAC key used to sign the tamper-evident audit chain. Auto-generated if unset
# (changes on every restart, so set this in production).
# VERITY_AUDIT_SECRET=<long random hex>
