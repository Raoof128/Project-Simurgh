ANTHROPIC_API_KEY=sk-ant-...
PORT=3030

# Optional — model selection (default: claude-sonnet-4-6)
# Set to claude-haiku-4-5 for the cost-sensitive deployment tier.
SIMURGH_MODEL=claude-sonnet-4-6

# Optional — force the local heuristic fallback (no Anthropic calls).
# Useful for offline demos. Default: 0.
SIMURGH_DEMO_MODE=0

# REQUIRED in non-demo mode. Native helper auth — must match the --secret
# flag passed to simurgh-helper. Choose a long, random value. The server
# will refuse to start in non-demo mode if this is unset.
# Generate with:  openssl rand -hex 32
SIMURGH_HELPER_SECRET=

# REQUIRED in production. HMAC key used to sign the tamper-evident audit chain.
# If unset the server generates an ephemeral key per restart, which silently
# invalidates every previously exported audit chain on each restart.
# Generate with:  openssl rand -hex 32
SIMURGH_AUDIT_SECRET=

# REQUIRED in production. Token gating the instructor view, dashboard,
# audit export, sessions list, and SSE stream. If unset, the server
# auto-generates a token per restart and prints it to stdout.
# Generate with:  openssl rand -hex 24
SIMURGH_INSTRUCTOR_TOKEN=

# Optional — restrict CORS to a specific origin. Default: "*" (any origin).
# Example: SIMURGH_ALLOWED_ORIGIN=https://exam.example.edu
SIMURGH_ALLOWED_ORIGIN=*

# REQUIRED in non-demo mode. HMAC key used to sign student session tokens
# (issued at /api/exams/:id/join, required on lifecycle + joined-session
# telemetry POSTs). Must be distinct from the audit, helper, and instructor
# secrets. The server refuses to start in non-demo mode if this is unset.
# Generate with:  openssl rand -hex 32
SIMURGH_SESSION_SIGNING_SECRET=

# Optional — risk scoring / Claude gating
SIMURGH_SCORING_MODE=hybrid
SIMURGH_CLAUDE_ON_SAFE=false
SIMURGH_CLAUDE_ON_WARNING=true
SIMURGH_CLAUDE_ON_CRITICAL=true

# Optional — require signed localhost daemon proofs on telemetry.
# Keep false for browser-only demos; set true for hardened/native-required exams.
SIMURGH_REQUIRE_DAEMON=false

# Optional — telemetry validation windows (ms)
SIMURGH_TIMESTAMP_SKEW_MS=30000
SIMURGH_TIMESTAMP_FUTURE_MS=5000

# Optional — JSON body limit (default 32kb)
SIMURGH_JSON_LIMIT=32kb

# Optional — capacity guards
SIMURGH_MAX_SESSIONS=10000

# Optional — session token TTL (ms, default 4 hours)
SIMURGH_SESSION_TTL_MS=14400000

# Optional — privacy debug toggles (do NOT enable in production)
SIMURGH_DEBUG_RAW_PROCESS_NAMES=false
SIMURGH_DEBUG_RAW_WINDOW_TITLES=false

# Voting pilot — MQ Persian Society research pilot (Phase A/B/C)
# REQUIRED when running the voting pilot routes.
# Generate with:  openssl rand -hex 32
SIMURGH_VOTING_PILOT_PEPPER=replace-with-32-char-random-secret
SIMURGH_VOTING_PILOT_TOKEN_SECRET=replace-with-32-char-random-secret

# Set to "true" to enforce server-side collection closure (Phase C closed).
# When true, consent/accept, submit, and withdraw return 410 Gone.
# Report export remains available for existing sessions.
SIMURGH_VOTING_PILOT_COLLECTION_CLOSED=false
