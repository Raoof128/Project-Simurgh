ANTHROPIC_API_KEY=sk-ant-...
PORT=3030

# Optional — model selection (default: claude-sonnet-4-5)
# Set to claude-haiku-4-5 for the cost-sensitive deployment tier.
VERITY_MODEL=claude-sonnet-4-5

# Optional — force the local heuristic fallback (no Anthropic calls).
# Useful for offline demos. Default: 0.
VERITY_DEMO_MODE=0

# REQUIRED in non-demo mode. Native helper auth — must match the --secret
# flag passed to verity-helper. Choose a long, random value. The server
# will refuse to start in non-demo mode if this is unset.
# Generate with:  openssl rand -hex 32
VERITY_HELPER_SECRET=

# REQUIRED in production. HMAC key used to sign the tamper-evident audit chain.
# If unset the server generates an ephemeral key per restart, which silently
# invalidates every previously exported audit chain on each restart.
# Generate with:  openssl rand -hex 32
VERITY_AUDIT_SECRET=

# REQUIRED in production. Token gating the instructor view, dashboard,
# audit export, sessions list, and SSE stream. If unset, the server
# auto-generates a token per restart and prints it to stdout.
# Generate with:  openssl rand -hex 24
VERITY_INSTRUCTOR_TOKEN=

# Optional — restrict CORS to a specific origin. Default: "*" (any origin).
# Example: VERITY_ALLOWED_ORIGIN=https://exam.example.edu
VERITY_ALLOWED_ORIGIN=*
